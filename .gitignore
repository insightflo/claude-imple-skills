# ============================================
# claude-impl-tools .gitignore
# ============================================

# --------------------------------------------
# 배포 제외 (로컬 전용)
# --------------------------------------------

# Skills 로컬 설정 (별도 배포)
.claude/

# Opencode 설정 (임시)
.sisyphus

# 로컬 프로젝트 지침 (프로젝트별 설정)
CLAUDE.md

# 로컬 구현 계획 문서
docs/

# MCP 설정 (사용자별 설정)
.mcp.json

# Git Worktree (임시 작업 디렉토리)
worktree/

# 개발용 에이전트 가이드/태스크 (배포 불필요)
AGENTS.md
TASKS.md

# 로컬 참고 자료 (배포 불필요)
ref/

# 로컬 테스트 (배포 불필요)
tests/

# multi-ai-review 실행 산출물 (로컬/CI 런타임 생성)
skills/multi-ai-review/.jobs/
skills/multi-ai-review/.jobs/**

# --------------------------------------------
# OS 생성 파일
# --------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --------------------------------------------
# 에디터/IDE
# --------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# --------------------------------------------
# 로그
# --------------------------------------------
*.log
npm-debug.log*

# --------------------------------------------
# 의존성
# --------------------------------------------
node_modules/
__pycache__/
*.pyc
.pytest_cache/
.coverage
htmlcov/

# --------------------------------------------
# 환경 설정 (민감 정보)
# --------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# --------------------------------------------
# 임시 파일
# --------------------------------------------
*.tmp
*.temp
*.bak
*.backup-*

# --------------------------------------------
# 빌드 산출물
# --------------------------------------------
dist/
build/
*.egg-info/
target/

# ============================================
# 배포 포함 (명시적)
# ============================================
# 아래 파일들은 .gitignore 규칙에서 제외 (배포에 포함)
#
# skills/                    - 우리스킬 (10개)
# project-team/       - AI 팀 협업 시스템
#   ├── hooks/               - 10개 Hook
#   ├── agents/              - 9개 에이전트
#   ├── templates/           - 프로토콜, ADR, Contract
#   ├── examples/            - ecommerce, saas 예제
#   ├── docs/                - 설치, 사용, 유지보수 문서
#   ├── install.sh           - 설치 스크립트
#   └── README.md            - 상세 문서
# scripts/                   - 설치 스크립트
# README.md                  - 메인 문서
# LICENSE                    - 라이선스
# TASKS.md                   - 개발 태스크 (참고용)
# ============================================
